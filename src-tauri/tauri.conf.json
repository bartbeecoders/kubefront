{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KubeFront",
  "version": "0.5.0",
  "identifier": "dev.kube-front.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KubeFront — K3S & Kubernetes Desktop",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "A modern desktop frontend for K3S & Kubernetes clusters.",
    "longDescription": "KubeFront is a lightweight, cross-platform desktop frontend for K3S and Kubernetes clusters. It uses your existing kubeconfig and renders a modern web UI in a native WebView.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
